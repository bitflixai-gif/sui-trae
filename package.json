{
  "name": "sui24-trade-mlm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "@fastify/sensible": "^6.0.1",
    "@vercel/node": "^3.0.0",
    "fastify": "^4.26.2",
    "pg": "^8.11.3",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "argon2": "^0.41.1",
    "uuid": "^9.0.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.2",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg": "^8.11.4",
    "@types/node-cron": "^3.0.11"
  },
  "engines": {
    "node": ">=18"
  }
}
